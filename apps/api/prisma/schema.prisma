generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  OTHER
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String
  name                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  leads                Lead[]
  activityLogs         ActivityLog[]
  followUpReminders    FollowUpReminder[]
  passwordResetTokens  PasswordResetToken[]
}

model Lead {
  id                String             @id @default(uuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  email             String?
  phone             String?
  company           String?
  jobTitle          String?
  stage             LeadStage          @default(NEW)
  notes             String?
  dealValue         Decimal?           @db.Decimal(10, 2)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activityLogs      ActivityLog[]
  followUpReminders FollowUpReminder[]

  @@index([userId])
  @@index([stage])
  @@index([userId, stage])
}

model ActivityLog {
  id        String       @id @default(uuid())
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  content   String
  createdAt DateTime     @default(now())

  @@index([leadId])
  @@index([userId])
}

model FollowUpReminder {
  id          String    @id @default(uuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dueAt       DateTime
  note        String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, dueAt])
  @@index([leadId])
  @@index([userId, isCompleted])
  @@index([isCompleted, dueAt, notifiedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
}
