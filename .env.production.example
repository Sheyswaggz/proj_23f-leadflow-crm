# ⚠️  WARNING: NEVER commit this file with real values!
# Set these values in Railway environment variables UI

# Server Configuration
NODE_ENV=production
PORT=3001

# Database Configuration
# Railway PostgreSQL URL (automatically provided by Railway)
DATABASE_URL=<Railway PostgreSQL URL>

# Redis Configuration
# Railway Redis URL (automatically provided by Railway)
REDIS_URL=<Railway Redis URL>

# JWT Configuration
# Generate with: openssl rand -base64 64
JWT_SECRET=<generate with: openssl rand -base64 64>
JWT_EXPIRES_IN=7d

# Email Configuration
# Production SMTP host (e.g., smtp.sendgrid.net, smtp.gmail.com, smtp.mailgun.org)
SMTP_HOST=<production SMTP host e.g. smtp.sendgrid.net>
SMTP_PORT=587
SMTP_USER=<SMTP username>
SMTP_PASS=<SMTP password>
FROM_EMAIL=noreply@yourdomain.com

# Frontend URL
# Railway web service URL (e.g., https://your-app.up.railway.app)
FRONTEND_URL=<Railway web service URL>

# CORS Configuration
# Railway web service URL (same as FRONTEND_URL)
CORS_ORIGIN=<Railway web service URL>

# Password Reset
PASSWORD_RESET_EXPIRES_IN=1h

# Logging
LOG_LEVEL=info

# Optional: Sentry DSN for error monitoring
# Leave empty to disable Sentry
SENTRY_DSN=<optional Sentry DSN>

# Reminder Notifications
# Set to true to enable automatic reminder email notifications
REMINDER_NOTIFICATIONS_ENABLED=true

# Bcrypt Configuration
# Number of salt rounds for password hashing (recommended: 12)
BCRYPT_ROUNDS=12
