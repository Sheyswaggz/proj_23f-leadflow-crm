# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgresql://leadflow:leadflow_password@postgres:5432/leadflow_dev

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_EXPIRES_IN=7d

# Email Configuration
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@leadflow.local

# Frontend URL
FRONTEND_URL=http://localhost:5173

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Password Reset
PASSWORD_RESET_EXPIRES_IN=1h

# Logging
# Log level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# Optional: Sentry DSN for error monitoring (leave empty to disable)
SENTRY_DSN=

# Set to false to disable automatic reminder email notifications
REMINDER_NOTIFICATIONS_ENABLED=true
