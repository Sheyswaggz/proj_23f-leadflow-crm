# Application Environment
NODE_ENV=development

# Database Configuration
# PostgreSQL connection string for local development
DATABASE_URL=postgresql://leadflow:leadflow_password@localhost:5432/leadflow_dev

# Redis Configuration
# Redis connection string for caching and sessions
REDIS_URL=redis://localhost:6379

# JWT Configuration
# Secret key for signing JWT tokens - CHANGE THIS to a random 256-bit secret in production
JWT_SECRET=change-this-to-a-random-256-bit-secret
# JWT token expiration time
JWT_EXPIRES_IN=7d

# SMTP Configuration
# SMTP server settings for sending emails (using Mailhog for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Email address used in the "From" field
FROM_EMAIL=noreply@leadflow.local

# Frontend Configuration
# URL where the frontend application is running
FRONTEND_URL=http://localhost:5173

# API Configuration
# Port on which the API server will listen
API_PORT=3001
# Allowed origins for CORS requests
CORS_ORIGIN=http://localhost:5173

# Password Reset
# Password reset token expiration time
PASSWORD_RESET_EXPIRES_IN=1h
